{
  "name": "@echo/ip-service",
  "version": "2.0.10",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "ipdb:fetch": "bun run scripts/ipdb-fetch.ts",
    "ipdb:compress": "bun run scripts/ipdb-compress.ts",
    "ipdb:update": "bun run ipdb:fetch -- --verify && bun run release -- patch --yes",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "bun run test && bun run test:e2e",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --max-warnings=0 .",
    "release": "bun run scripts/release.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.30",
    "ip2region.js": "^3.1.8",
    "lru-cache": "^11.5.2",
    "maxmind": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "mmdb-lib": "^3.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
